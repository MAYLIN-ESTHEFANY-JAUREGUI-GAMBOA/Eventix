<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" 
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports 
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" 
              name="ReporteEventos" pageWidth="842" pageHeight="595" 
              orientation="Landscape" columnWidth="802" rowHeight="15" 
              whenNoDataType="NoPages" columnCount="1" 
              printOrder="Vertical" offset="0" runDirection="LTR">
    
    <property name="ireport.zoom" value="1.0"/>
    <property name="ireport.x" value="0"/>
    <property name="ireport.y" value="0"/>
    
    <parameter name="TITULO" class="java.lang.String">
        <defaultValueExpression><![CDATA["Reporte de Eventos"]]></defaultValueExpression>
    </parameter>
    
    <field name="id" class="java.lang.Integer"/>
    <field name="nombreEvento" class="java.lang.String"/>
    <field name="tipoEvento" class="java.lang.String"/>
    <field name="modalidad" class="java.lang.String"/>
    <field name="servicios" class="java.lang.String"/>
    <field name="fechaEvento" class="java.sql.Date"/>
    <field name="costo" class="java.math.BigDecimal"/>
    <field name="estado" class="java.lang.String"/>
    
    <background>
        <band height="0"/>
    </background>
    
    <title>
        <band height="80">
            <staticText>
                <reportElement x="0" y="20" width="802" height="40" 
                               forecolor="#4682B4" backcolor="#FFFFFF"/>
                <textElement textAlignment="Center">
                    <font size="24" isBold="true"/>
                </textElement>
                <text><![CDATA[SISTEMA DE GESTIÓN DE EVENTOS]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="60" width="802" height="20"/>
                <textElement textAlignment="Center">
                    <font size="14"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{TITULO}]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="0" y="79" width="802" height="1" forecolor="#4682B4"/>
            </line>
        </band>
    </title>
    
    <pageHeader>
        <band height="30">
            <staticText>
                <reportElement x="0" y="5" width="802" height="20"/>
                <textElement>
                    <font size="10" isItalic="true"/>
                </textElement>
                <text><![CDATA[Fecha de emisión:]]></text>
            </staticText>
            <textField pattern="dd/MM/yyyy HH:mm:ss">
                <reportElement x="100" y="5" width="200" height="20"/>
                <textElement/>
                <textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
            </textField>
        </band>
    </pageHeader>
    
    <columnHeader>
        <band height="30">
            <staticText>
                <reportElement x="0" y="5" width="50" height="20" 
                               forecolor="#FFFFFF" backcolor="#4682B4"/>
                <textElement textAlignment="Center">
                    <font size="12" isBold="true"/>
                </textElement>
                <text><![CDATA[ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="50" y="5" width="150" height="20" 
                               forecolor="#FFFFFF" backcolor="#4682B4"/>
                <textElement textAlignment="Center">
                    <font size="12" isBold="true"/>
                </textElement>
                <text><![CDATA[Nombre]]></text>
            </staticText>
            <staticText>
                <reportElement x="200" y="5" width="100" height="20" 
                               forecolor="#FFFFFF" backcolor="#4682B4"/>
                <textElement textAlignment="Center">
                    <font size="12" isBold="true"/>
                </textElement>
                <text><![CDATA[Tipo]]></text>
            </staticText>
            <staticText>
                <reportElement x="300" y="5" width="100" height="20" 
                               forecolor="#FFFFFF" backcolor="#4682B4"/>
                <textElement textAlignment="Center">
                    <font size="12" isBold="true"/>
                </textElement>
                <text><![CDATA[Modalidad]]></text>
            </staticText>
            <staticText>
                <reportElement x="400" y="5" width="150" height="20" 
                               forecolor="#FFFFFF" backcolor="#4682B4"/>
                <textElement textAlignment="Center">
                    <font size="12" isBold="true"/>
                </textElement>
                <text><![CDATA[Servicios]]></text>
            </staticText>
            <staticText>
                <reportElement x="550" y="5" width="100" height="20" 
                               forecolor="#FFFFFF" backcolor="#4682B4"/>
                <textElement textAlignment="Center">
                    <font size="12" isBold="true"/>
                </textElement>
                <text><![CDATA[Fecha]]></text>
            </staticText>
            <staticText>
                <reportElement x="650" y="5" width="80" height="20" 
                               forecolor="#FFFFFF" backcolor="#4682B4"/>
                <textElement textAlignment="Center">
                    <font size="12" isBold="true"/>
                </textElement>
                <text><![CDATA[Costo]]></text>
            </staticText>
            <staticText>
                <reportElement x="730" y="5" width="72" height="20" 
                               forecolor="#FFFFFF" backcolor="#4682B4"/>
                <textElement textAlignment="Center">
                    <font size="12" isBold="true"/>
                </textElement>
                <text><![CDATA[Estado]]></text>
            </staticText>
        </band>
    </columnHeader>
    
    <detail>
        <band height="25">
            <textField>
                <reportElement x="0" y="2" width="50" height="20"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{id}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="50" y="2" width="150" height="20"/>
                <textElement/>
                <textFieldExpression><![CDATA[$F{nombreEvento}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="200" y="2" width="100" height="20"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{tipoEvento}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="300" y="2" width="100" height="20"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{modalidad}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="400" y="2" width="150" height="20"/>
                <textElement/>
                <textFieldExpression><![CDATA[$F{servicios}]]></textFieldExpression>
            </textField>
            <textField pattern="dd/MM/yyyy">
                <reportElement x="550" y="2" width="100" height="20"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{fechaEvento}]]></textFieldExpression>
            </textField>
            <textField pattern="###,##0.00">
                <reportElement x="650" y="2" width="80" height="20"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[$F{costo}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="730" y="2" width="72" height="20"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{estado}]]></textFieldExpression>
            </textField>
        </band>
    </detail>
    
    <pageFooter>
        <band height="30">
            <line>
                <reportElement x="0" y="0" width="802" height="1" forecolor="#4682B4"/>
            </line>
            <staticText>
                <reportElement x="0" y="10" width="802" height="20"/>
                <textElement textAlignment="Center">
                    <font size="9" isItalic="true"/>
                </textElement>
                <text><![CDATA[Página ]]></text>
            </staticText>
            <textField>
                <reportElement x="350" y="10" width="100" height="20"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>
    
</jasperReport>
